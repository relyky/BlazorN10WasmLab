@inherits LayoutComponentBase

<div class="flex flex-col h-screen">
    <header class="flex items-center shrink-0 bg-primary text-primary-fg px-4 py-3 shadow-md">
        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-white text-primary font-bold text-lg mr-3 shrink-0">B</div>
        <span class="text-xl font-bold flex-1">BlazorN10WasmLab</span>
        <span class="text-sm opacity-75 hidden sm:block">Blazor .NET 10 WASM Lab</span>
    </header>

    <div class="flex flex-1 overflow-hidden">
        <nav class="w-60 shrink-0 bg-white border-r border-gray-200 overflow-y-auto">
            <NavMenu />
        </nav>
        <main class="flex-1 overflow-y-auto bg-gray-50 p-6">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
