@page "/counter"

<PageTitle>Counter</PageTitle>

<h1 class="text-4xl font-bold text-[var(--color-primary)] my-4">Counter</h1>

<p role="status">Current count: <span class="text-5xl font-bold text-sky-300">@currentCount</span></p>

<button class="bg-[var(--color-primary)] text-[var(--color-primary-fg)] rounded-md px-5 py-2 font-medium cursor-pointer shadow-sm" @onclick="IncrementCount">Click me</button>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
