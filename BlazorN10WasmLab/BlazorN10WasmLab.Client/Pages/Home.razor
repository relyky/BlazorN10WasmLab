@page "/"

<PageTitle>Home</PageTitle>

<div class="max-w-5xl mx-auto space-y-6">

    @* 公告 Banner *@
    <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-4">
        <div class="flex items-start gap-3">
            <div class="text-primary mt-0.5 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
            </div>
            <div>
                <p class="font-semibold text-gray-800">最新公告</p>
                <p class="text-sm text-gray-600 mt-0.5">主旨：歡迎使用 BlazorN10WasmLab 實驗室</p>
                <p class="text-sm text-gray-500 mt-0.5">說明：本專案展示 Blazor WebAssembly + .NET 10 + gRPC-Web + Tailwind CSS v4 的整合。</p>
            </div>
        </div>
    </div>

    @* App 卡片 Grid *@
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

        <a href="/counter" class="block bg-white rounded-lg border border-gray-200 shadow-sm p-4 hover:shadow-md hover:border-primary transition-all cursor-pointer no-underline">
            <div class="flex items-center gap-3">
                <div class="flex items-center justify-center w-11 h-11 rounded-full bg-primary text-primary-fg font-bold text-lg shrink-0">C</div>
                <div>
                    <p class="font-semibold text-gray-800">Counter</p>
                    <p class="text-sm text-gray-500">計數器</p>
                </div>
            </div>
        </a>

        <a href="/weather" class="block bg-white rounded-lg border border-gray-200 shadow-sm p-4 hover:shadow-md hover:border-primary transition-all cursor-pointer no-underline">
            <div class="flex items-center gap-3">
                <div class="flex items-center justify-center w-11 h-11 rounded-full bg-primary text-primary-fg font-bold text-lg shrink-0">W</div>
                <div>
                    <p class="font-semibold text-gray-800">Weather</p>
                    <p class="text-sm text-gray-500">天氣預報（gRPC-Web）</p>
                </div>
            </div>
        </a>

    </div>
</div>
